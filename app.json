{
  "expo": {
    "name": "MyManager",
    "slug": "my-manager",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "mymanager",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.unnotomoyuki.mymanager",
      "adaptiveIcon": {
        "backgroundColor": "#111827"
      }
    },
    "plugins": [
      "expo-sqlite",
      "expo-notifications",
      "expo-asset"
    ],
    "extra": {
      "supabaseUrl": "${EXPO_PUBLIC_SUPABASE_URL}",
      "supabaseAnonKey": "${EXPO_PUBLIC_SUPABASE_ANON_KEY}"
    }
  }
}
